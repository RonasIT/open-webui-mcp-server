{
  "name": "open-webui-knowledge-mcp-server",
  "version": "0.0.1",
  "description": "MCP Server for Open WebUI Knowledge Bases – search and access knowledge bases from Cursor, Claude Desktop, and other MCP clients",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "open-webui-knowledge-mcp-server": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js",
    "lint": "npx tsc && npx eslint ./",
    "format": "npx prettier --write . && npm run lint -- --fix",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "release": "npm publish",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RonasIT/open-webui-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "open-webui",
    "knowledge-base",
    "cursor",
    "claude"
  ],
  "author": "Ronas IT",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/RonasIT/open-webui-mcp-server/issues"
  },
  "homepage": "https://github.com/RonasIT/open-webui-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "hono": "^4.11.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^22.12.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  }
}